# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tripgenie
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Server
PORT=3000
CLIENT_URL=http://127.0.0.1:5500
